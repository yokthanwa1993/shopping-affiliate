{
  "name": "shopee-shortlink",
  "version": "1.0.0",
  "description": "Shopee Affiliate Shortlink Generator",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.shopee.shortlink",
    "productName": "Shopee Shortlink",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "icons/icon.icns",
      "target": [{
        "target": "dmg",
        "arch": ["arm64", "x64"]
      }]
    },
    "dmg": {
      "title": "Shopee Shortlink"
    },
    "files": ["main.js", "icons/**"],
    "extraMetadata": {
      "main": "main.js"
    }
  },
  "dependencies": {
    "ws": "^8.19.0"
  }
}
