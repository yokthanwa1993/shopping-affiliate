{
    "name": "video-affiliate-worker",
    "account_id": "bc047db265944dddff5f07cfa6ef45aa",
    "main": "src/index.ts",
    "compatibility_date": "2026-02-14",
    "compatibility_flags": [
        "nodejs_compat",
        "global_fetch_strictly_public"
    ],
    // Pipeline ใช้เวลา 2-3 นาที
    "limits": {
        "cpu_ms": 300000
    },
    // Container: FFmpeg merge service
    "containers": [
        {
            "class_name": "MergeContainer",
            "image": "registry.cloudflare.com/bc047db265944dddff5f07cfa6ef45aa/video-affiliate-worker-mergecontainer:v2026-03-29.01",
            "instance_type": "standard-2",
            "max_instances": 2
        }
    ],
    // Durable Objects (Container = DO)
    "durable_objects": {
        "bindings": [
            {
                "name": "MERGE_CONTAINER",
                "class_name": "MergeContainer"
            }
        ]
    },
    // DO migrations
    "migrations": [
        {
            "tag": "v1",
            "new_sqlite_classes": [
                "MergeContainer"
            ]
        }
    ],
    // D1 Database
    "d1_databases": [
        {
            "binding": "DB",
            "database_name": "video-affiliate-db",
            "database_id": "313a798a-3a03-447c-8329-296afb8eead8"
        }
    ],
    // R2 Bucket
    "r2_buckets": [
        {
            "binding": "BUCKET",
            "bucket_name": "video-affiliate-videos"
        }
    ],
    // Environment variables
    "vars": {
        "CORS_ORIGIN": "*",
        "WORKER_URL": "https://video-affiliate-worker.onlyy-gor.workers.dev",
        "R2_PUBLIC_URL": "https://pub-14b6c1dd39f14ed7a219a84afc93c182.r2.dev",
        "GEMINI_MODEL": "gemini-3-flash-preview",
        "WEBAPP_URL": "https://video-affiliate-webapp-38v.pages.dev",
        "BROWSERSAVING_WORKER_URL": "https://browsersaving-worker.yokthanwa1993-bc9.workers.dev",
        "BROWSERSAVING_API_URL": "https://browsersaving-api.lslly.com"
    },
    "observability": {
        "enabled": true
    },
    // Cron triggers - run every minute for auto-posting
    "triggers": {
        "crons": [
            "* * * * *"
        ]
    },
    // Secrets (set via `wrangler secret put`):
    // TELEGRAM_BOT_TOKEN
    // TAG_SYNC_PUSH_SECRET
}
