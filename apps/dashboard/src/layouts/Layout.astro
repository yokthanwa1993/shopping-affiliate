---
import '../styles/global.css'

export type DashboardTab = 'dashboard' | 'gallery' | 'inbox' | 'processing' | 'page-posts' | 'custom-link' | 'running' | 'create' | 'queue' | 'history' | 'settings'

export interface Props {
  title: string
  active?: DashboardTab
  subtitle?: string
  headerBadge?: string
}

const { title, active = 'dashboard', subtitle, headerBadge } = Astro.props

type NavItem = {
  id: DashboardTab
  label: string
  href: string
  icon: string
  enabled: boolean
}

// Sidebar items mirror the legacy Ads Manager dashboard ordering. Every route
// here is wired to a working page in V3.
const navItems: NavItem[] = [
  { id: 'dashboard',  label: 'Dashboard',     href: '/dashboard/',                  icon: 'layout',   enabled: true },
  { id: 'gallery',    label: 'แกลลี่',         href: '/dashboard/gallery/',          icon: 'layers',   enabled: true },
  { id: 'inbox',      label: 'คลังต้นฉบับ',     href: '/dashboard/source-inventory/', icon: 'inbox',    enabled: true },
  { id: 'processing', label: 'Processing',    href: '/dashboard/processing/',       icon: 'cpu',      enabled: true },
  { id: 'page-posts', label: 'โพสต์เพจ',       href: '/dashboard/page_posts/',       icon: 'facebook', enabled: true },
  { id: 'custom-link', label: 'Custom Link',   href: '/dashboard/custom-link/',      icon: 'link',     enabled: true },
  { id: 'running',    label: 'Campaigns',     href: '/dashboard/campaigns/',        icon: 'mega',     enabled: true },
  { id: 'create',     label: 'Create Ads',    href: '/dashboard/create-ads/',       icon: 'users',    enabled: true },
  { id: 'queue',      label: 'คิวสร้างแอด',     href: '/dashboard/queue/',            icon: 'clock',    enabled: true },
  { id: 'history',    label: 'History',       href: '/dashboard/history/',          icon: 'msg',      enabled: true },
]

const settingsItem: NavItem = { id: 'settings', label: 'Settings', href: '/dashboard/settings/', icon: 'cog', enabled: true }
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content="Dashboard V3 (Astro)" />
    <meta name="dashboard-version" content="v3" />
    <title>{title} · Ads Manager · PUBILO</title>
  </head>
  <body class="h-screen overflow-hidden bg-[#f6f8fb] text-slate-900 antialiased">
    <div class="flex h-screen min-h-0 flex-col lg:flex-row">
      <aside class="w-full shrink-0 border-b border-slate-200 bg-white lg:h-screen lg:w-72 lg:border-b-0 lg:border-r">
        <div class="flex h-full flex-col overflow-hidden p-3">
          {/* Identity card — operator + active workspace. Replaces the legacy
              Facebook-page card so the sidebar reflects who is signed in, not
              which page is being managed (pages live inside Ads Manager). */}
          <a
            href="/dashboard/settings/"
            class="flex w-full items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-3 py-3 text-left transition hover:bg-slate-100"
          >
            <span
              aria-hidden="true"
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-slate-900 to-slate-700 text-sm font-semibold text-white ring-1 ring-slate-200"
            >
              YK
            </span>
            <div class="min-w-0 flex-1">
              <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">PUBILO · Workspace</p>
              <p class="truncate text-sm font-semibold text-slate-900">YOK</p>
            </div>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 text-slate-400"><polyline points="9 18 15 12 9 6"/></svg>
          </a>

          <nav class="mt-4 space-y-1.5 overflow-y-auto pr-1">
            {navItems.map((item) => {
              const isActive = active === item.id
              return (
                <a
                  href={item.href}
                  data-tab={item.id}
                  aria-current={isActive ? 'page' : undefined}
                  class:list={[
                    'flex w-full items-center justify-between rounded-2xl px-3 py-2.5 text-left transition',
                    isActive
                      ? 'bg-slate-900 text-white'
                      : item.enabled
                        ? 'text-slate-600 hover:bg-slate-100'
                        : 'text-slate-400 hover:bg-slate-50',
                  ]}
                >
                  <span class="flex items-center gap-3">
                    <span
                      class:list={[
                        'inline-flex h-[17px] w-[17px] items-center justify-center',
                        isActive ? 'text-white' : 'text-slate-400',
                      ]}
                    >
                      {item.icon === 'layout' && (
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
                      )}
                      {item.icon === 'layers' && (
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                      )}
                      {item.icon === 'inbox' && (
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
                      )}
                      {item.icon === 'cpu' && (
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>
                      )}
                      {item.icon === 'facebook' && (
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                      )}
                      {item.icon === 'link' && (
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                      )}
                      {item.icon === 'mega' && (
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 11l18-5v12L3 13z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>
                      )}
                      {item.icon === 'users' && (
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                      )}
                      {item.icon === 'clock' && (
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      )}
                      {item.icon === 'msg' && (
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                      )}
                    </span>
                    <span class="text-sm font-medium">{item.label}</span>
                  </span>
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class={isActive ? 'text-white/70' : 'text-slate-300'}><polyline points="9 18 15 12 9 6"/></svg>
                </a>
              )
            })}
          </nav>

          <div class="mt-auto hidden space-y-1.5 lg:block">
            <a
              href={settingsItem.href}
              class:list={[
                'flex w-full items-center gap-3 rounded-2xl px-3 py-2 text-left text-sm transition',
                active === 'settings'
                  ? 'bg-slate-900 text-white'
                  : 'text-slate-400 hover:bg-slate-50',
              ]}
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              <span>Settings</span>
            </a>
            <p class="px-3 pt-2 text-[10px] uppercase tracking-[0.18em] text-slate-300">PUBILO · v3 console</p>
          </div>
        </div>
      </aside>

      <div class="min-w-0 min-h-0 flex-1 overflow-hidden">
        <div class="flex h-full min-h-0 flex-col overflow-hidden bg-[#f6f8fb]">
          <header class="sticky top-0 z-30 shrink-0 flex items-center justify-between gap-4 border-b border-slate-200 bg-white px-4 py-3 sm:px-6">
            <div class="flex items-center gap-3 min-w-0">
              <div class="rounded-xl bg-slate-100 p-2 text-slate-600">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>
              </div>
              <div class="min-w-0">
                <div class="flex items-center gap-2">
                  <p class="truncate text-sm font-semibold">{title}</p>
                  {headerBadge && (
                    <span class="rounded-full bg-slate-100 px-2.5 py-1 text-[11px] font-semibold text-slate-600">{headerBadge}</span>
                  )}
                </div>
                <p class="truncate text-xs text-slate-500">{subtitle ?? 'Ads manager workspace'}</p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <a
                href="https://api.pubilo.com"
                target="_blank"
                rel="noreferrer"
                class="hidden rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50 sm:inline-flex"
              >
                Worker API
              </a>
              <a
                href="https://business.facebook.com/adsmanager"
                target="_blank"
                rel="noreferrer"
                class="rounded-xl bg-[#1877f2] px-3 py-2 text-sm font-semibold text-white hover:bg-[#166fe0]"
              >
                Open Ads Manager
              </a>
            </div>
          </header>

          <main class="scrollbar-thin min-h-0 flex-1 overflow-y-auto overflow-x-hidden px-4 py-4 sm:px-6">
            <slot />
          </main>
        </div>
      </div>
    </div>
  </body>
</html>
