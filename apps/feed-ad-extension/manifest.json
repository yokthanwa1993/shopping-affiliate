{
    "manifest_version": 3,
    "name": "Feed Ad Creator",
    "version": "1.4.0",
    "description": "เบื้องหลังของ dashboard /feed — shortlink + ดึงโทเค้น/cookies จาก Ads Manager tab + รัน FB pipeline. ไม่มี UI (ทำงานเงียบๆ ผ่าน dashboard.oomnn.com/feed เท่านั้น). ฟีดเท่านั้น เฉียบไม่แตะ",
    "permissions": [
        "tabs",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://adsmanager.facebook.com/*",
        "https://www.facebook.com/*",
        "https://graph.facebook.com/*",
        "https://affiliate.shopee.co.th/*",
        "https://short.wwoom.com/*",
        "https://api.oomnn.com/*"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://dashboard.oomnn.com/*",
                "https://ads-manager-dashboard.yokthanwa1993-bc9.workers.dev/*"
            ],
            "js": [
                "bridge.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_title": "Feed Ad Creator (เบื้องหลังของ dashboard /feed)",
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png",
            "128": "icons/icon-128.png"
        }
    },
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    }
}
