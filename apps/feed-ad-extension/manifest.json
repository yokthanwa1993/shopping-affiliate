{
    "manifest_version": 3,
    "name": "Feed Ad Creator",
    "version": "1.1.0",
    "description": "สร้างแอด LikePage ให้เพจ ฟีด (page id 116759241338040) ผ่าน Ads Manager session ใน Chrome — ทดแทน Electron flow ของฟีดเท่านั้น (เฉียบยังใช้ Electron เหมือนเดิม)",
    "permissions": [
        "tabs",
        "scripting",
        "sidePanel",
        "storage"
    ],
    "host_permissions": [
        "https://adsmanager.facebook.com/*",
        "https://www.facebook.com/*",
        "https://graph.facebook.com/*",
        "https://affiliate.shopee.co.th/*",
        "https://short.wwoom.com/*",
        "https://api.oomnn.com/*"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://dashboard.oomnn.com/*",
                "https://ads-manager-dashboard.yokthanwa1993-bc9.workers.dev/*"
            ],
            "js": [
                "bridge.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "side_panel": {
        "default_path": "panel.html"
    },
    "action": {
        "default_title": "Feed Ad Creator",
        "default_popup": "panel.html",
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png",
            "128": "icons/icon-128.png"
        }
    },
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    }
}
