# admin-media-drive configuration — copy to .env and fill in.
# NEVER commit a real .env or paste real tokens anywhere in the repo/wiki.

# HTTP server (always bound to 127.0.0.1)
PORT=3100

# Storage mode:
#   discord (default) — Discord is 100% of the storage for original + processed
#                       videos. The Mac mini only indexes metadata (SQLite);
#                       nothing is kept permanently under MEDIA_ROOT.
#   mirror            — legacy: ALSO keep a permanent local mirror. Optional.
STORAGE_MODE=discord

# Discord bot credentials (placeholders only — fill locally)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DEFAULT_CHANNEL_ID=

# Discord channels that hold the media (these are channel IDs, not secrets).
# SOURCE_CHANNEL_ID    = #คลังต้นฉบับ    — original files
# PROCESSED_CHANNEL_ID = #ประมวลผลแล้ว   — processed files
# Discovered example IDs (leave blank to disable a channel):
#   SOURCE_CHANNEL_ID=1522202812560310283
#   PROCESSED_CHANNEL_ID=1518808518176800769
SOURCE_CHANNEL_ID=
PROCESSED_CHANNEL_ID=

# Max size of a single upload, in bytes (default 10 MiB)
MAX_UPLOAD_BYTES=10485760

# Temp/cache dir. In discord mode (default) this is used ONLY transiently while
# processing a file and is not a permanent store. In mirror mode it is the
# permanent local mirror root (<yyyy>/<mm>/<attachmentId>_<safeFilename>).
MEDIA_ROOT=/Users/yok-macmini/AffiliateMedia/admin-media-drive

# SQLite index path (the parent directory is created automatically).
DB_PATH=/Users/yok-macmini/Library/Application Support/AffiliateAdmin/admin-media-drive.sqlite

# Logical namespace for indexed rows (lets one DB host several drives later).
NAMESPACE_ID=admin

# Local Mac processor. Default is the real video-affiliate merge-rust pipeline:
# download source URL -> flip/prepare -> Vertex Gemini analyze -> Thai script/title/category
# -> Vertex Gemini TTS -> audio duration fit -> Vertex Gemini audio SRT/fallback
# -> SRT to ASS -> centered subtitle burn -> thumbnail -> local callback upload.
PROCESSOR_MODE=merge_rust

# Where the merge-rust pipeline service lives. Blank AND loopback URLs
# (e.g. http://127.0.0.1:18080) are locally owned: the merge-rust LaunchAgent
# starts + supervises the service there (cargo, or MERGE_RUST_BIN if set), and
# the worker spawns it as a per-job fallback. Only a non-loopback URL is an
# external already-running service that is never started from here.
MERGE_RUST_URL=
MERGE_RUST_ROOT=/Users/yok-macmini/Developer/shopping-affiliate/apps/video-affiliate/merge-rust
MERGE_RUST_BIN=
MERGE_RUST_PORT=18080
MERGE_RUST_START_TIMEOUT_MS=180000
MERGE_RUST_JOB_TIMEOUT_MS=3600000
MERGE_RUST_CALLBACK_PORT=0
MERGE_RUST_CALLBACK_URL=

# Keep merge-rust's final upload under the Discord attachment cap. When the
# processor auto-starts merge-rust, this is passed as R2_UPLOAD_MAX_BYTES.
PROCESSOR_FINAL_UPLOAD_MAX_BYTES=10485760

# Vertex/Gemini settings used by merge-rust. GOOGLE_APPLICATION_CREDENTIALS may
# point at a local service-account JSON file; never commit or paste its contents.
GOOGLE_APPLICATION_CREDENTIALS=
PROCESSOR_GEMINI_MODEL=gemini-3-flash-preview
VERTEX_TTS_ENDPOINT=https://aiplatform.googleapis.com
VERTEX_TTS_PROJECT_ID=
VERTEX_TTS_LOCATION=global
VERTEX_TTS_MODEL=gemini-3.1-flash-tts-preview
PROCESSOR_VOICE_NAME=Puck

# --- Subtitle fail-closed verification gate ---------------------------------
# The local macOS FFmpeg lacks the libass `ass`/`subtitles`/`drawtext`
# filters, so merge-rust's subtitle burn fails OPEN (output keeps TTS audio
# but has no visible subtitles). The gate recovers with Pillow PNG overlays
# (legacy FC Iconic Bold style) via plain-ffmpeg `overlay`, then verifies
# decode/duration/per-cue pixels/audio-change BEFORE any Discord upload.
# Disabling it reverts to the false-success incident behavior.
SUBTITLE_GATE_ENABLED=1
# Managed Python venv (create with: npm run setup:venv). No global pip use.
SUBTITLE_PYTHON_BIN=/Users/yok-macmini/Developer/shopping-affiliate/apps/admin-media-drive/.venv/bin/python3
# Existing merge-rust overlay renderer + bundled FC Iconic Bold font.
#SUBTITLE_OVERLAY_HELPER=/Users/yok-macmini/Developer/shopping-affiliate/apps/video-affiliate/merge-rust/scripts/generate_overlay.py
#SUBTITLE_PROOF_HELPER=/Users/yok-macmini/Developer/shopping-affiliate/apps/admin-media-drive/scripts/subtitle_proof.py
#SUBTITLE_FONT_PATH=/Users/yok-macmini/Developer/shopping-affiliate/apps/video-affiliate/merge-rust/font.ttf
# Bounds for the overlay/verification pass.
SUBTITLE_MAX_CUES=240
SUBTITLE_MAX_SAMPLED_FRAMES=12
SUBTITLE_DURATION_TOLERANCE_MS=1500
# Lower/lower-middle text-box center (legacy ASS bottom-center MarginV=250).
SUBTITLE_CENTER_Y_RATIO=0.74

# --- MCP server (npm run mcp) ------------------------------------------------
# The stdio MCP server holds NO Discord/Vertex secrets; it only calls the
# loopback API below (non-loopback URLs are refused).
#ADMIN_MEDIA_DRIVE_API_URL=http://127.0.0.1:3100
# Allowlisted roots for media_submit_video local paths (colon-separated).
# Default: ~/Desktop:~/Downloads:~/Movies:~/AffiliateMedia/inbox
#MEDIA_SUBMIT_ALLOWED_ROOTS=/Users/yok-macmini/Desktop:/Users/yok-macmini/Downloads:/Users/yok-macmini/Movies:/Users/yok-macmini/AffiliateMedia/inbox

# Legacy fallback only. Set PROCESSOR_MODE=ffmpeg to use this simple local
# transcode path; it is not the default production-style processor.
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
# auto = prefer h264_videotoolbox on macOS when available, otherwise libx264.
# Set libx264 to force software encoding.
FFMPEG_VIDEO_ENCODER=auto
# Set to 1 only while debugging failed jobs; temp files are cleaned by default.
KEEP_PROCESSING_TMP=0
# Worker poll interval when running `npm run process`.
PROCESS_POLL_MS=30000
