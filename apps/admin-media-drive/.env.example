# admin-media-drive configuration — copy to .env and fill in.
# NEVER commit a real .env or paste real tokens anywhere in the repo/wiki.

# HTTP server (always bound to 127.0.0.1)
PORT=3100

# Discord bot credentials (placeholders only — fill locally)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DEFAULT_CHANNEL_ID=

# Max size of a single upload, in bytes (default 10 MiB)
MAX_UPLOAD_BYTES=10485760

# Local filesystem mirror root. Uploads + synced Discord media are written here
# as <yyyy>/<mm>/<attachmentId>_<safeFilename>.
MEDIA_ROOT=/Users/yok-macmini/AffiliateMedia/admin-media-drive

# SQLite index path (the parent directory is created automatically).
DB_PATH=/Users/yok-macmini/Library/Application Support/AffiliateAdmin/admin-media-drive.sqlite

# Logical namespace for indexed rows (lets one DB host several drives later).
NAMESPACE_ID=admin
