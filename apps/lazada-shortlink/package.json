{
  "name": "lazada-shortlink-electron",
  "version": "1.0.0",
  "description": "Lazada Affiliate link shortener",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.yok.lazada-shortlink",
    "productName": "Lazada Shortlink",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "extraResources": [
      "icon.png",
      "icon.ico"
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "runAfterFinish": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Lazada Shortlink",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  }
}
