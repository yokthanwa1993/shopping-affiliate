{
    "name": "browsersaving-worker",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "db:generate": "wrangler d1 migrations create browsersaving",
        "db:migrate:local": "wrangler d1 migrations apply browsersaving --local",
        "db:migrate:prod": "wrangler d1 migrations apply browsersaving --remote"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.980.0",
        "@aws-sdk/s3-request-presigner": "^3.980.0",
        "hono": "^4.0.0",
        "pako": "^2.1.0"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20240208.0",
        "@types/pako": "^2.0.4",
        "wrangler": "^3.0.0"
    }
}
